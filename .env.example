# ── 阿里雲百煉 (DashScope) ────────────────────────────────────────────
# 將本檔複製為 .env，填入大會提供的百煉代金券 API Key，
# 系統即會自動由「離線示範引擎」切換為真實 Qwen 千問模型驅動。
#
# 取得 Key：阿里雲百煉控制台 https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=

# OpenAI 相容端點（百煉預設，無須更改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 規劃用模型：qwen-plus（均衡）/ qwen-max（最強推理）/ qwen-turbo（最快）
QWEN_MODEL=qwen-plus

# 智能體單次規劃最多迭代步數
MAX_AGENT_STEPS=12
